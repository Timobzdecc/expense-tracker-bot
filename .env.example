# Telegram Bot Token (получи у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Белый список пользователей (Telegram ID через запятую)
# Если пусто — бот доступен ВСЕМ. Рекомендуется заполнить!
# Узнать свой ID: напиши @userinfobot в Telegram
ALLOWED_USERS=

# Google Gemini API Key (получи на https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Модель AI (по умолчанию gemini-2.0-flash)
# Доступные модели:
#   gemini-2.0-flash       — быстрая, бесплатная (рекомендуется)
#   gemini-2.5-flash       — новейшая быстрая
#   gemini-2.5-pro         — самая умная
#   gemma-3n-e4b-it        — Gemma 3n, лёгкая
#   gemma-3-27b-it         — Gemma 3 27B
#   gemma-3-12b-it         — Gemma 3 12B
#   gemma-3-4b-it          — Gemma 3 4B, самая компактная
GEMINI_MODEL=gemini-2.0-flash
